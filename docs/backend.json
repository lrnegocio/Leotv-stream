
{
  "entities": {
    "ContentItem": {
      "title": "Item de Conteúdo",
      "description": "Filme, série ou canal de TV",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["movie", "series", "multi-season", "channel"] },
        "genre": { "type": "string" },
        "isRestricted": { "type": "boolean" },
        "isActive": { "type": "boolean", "default": true },
        "streamUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "views": { "type": "number" },
        "episodes": { "type": "array" },
        "seasons": { "type": "array" }
      }
    },
    "User": {
      "title": "Cliente",
      "description": "Perfil de acesso via PIN",
      "type": "object",
      "properties": {
        "pin": { "type": "string" },
        "role": { "type": "string" },
        "gamePoints": { "type": "number" },
        "isGamesEnabled": { "type": "boolean" },
        "isAdultEnabled": { "type": "boolean" },
        "isPpvEnabled": { "type": "boolean" },
        "isAlacarteEnabled": { "type": "boolean" },
        "isGamesOnly": { "type": "boolean" },
        "subscriptionTier": { "type": "string" },
        "expiryDate": { "type": "string" },
        "maxScreens": { "type": "number" },
        "activeDevices": { "type": "array" },
        "individualMessage": { "type": "string" },
        "resellerId": { "type": "string" }
      }
    },
    "Reseller": {
      "title": "Revendedor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "credits": { "type": "number" },
        "totalSold": { "type": "number" },
        "isBlocked": { "type": "boolean" }
      }
    },
    "GameItem": {
      "title": "Jogo de Arena",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "console": { "type": "string" },
        "url": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/content/{contentId}": { "schema": "ContentItem", "description": "Biblioteca de canais e VOD" },
    "/users/{userId}": { "schema": "User", "description": "PINs de acesso" },
    "/resellers/{resellerId}": { "schema": "Reseller", "description": "Parceiros de revenda" },
    "/games/{gameId}": { "schema": "GameItem", "description": "Jogos da Arena" },
    "/settings/{settingId}": { "schema": "object", "description": "Configurações globais" }
  }
}
