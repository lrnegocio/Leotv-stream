
{
  "entities": {
    "ContentItem": {
      "title": "Item de Conteúdo",
      "description": "Filme, série ou canal de TV",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Nome do canal ou filme" },
        "type": { "type": "string", "enum": ["movie", "series", "multi-season", "channel"], "description": "Tipo de mídia" },
        "description": { "type": "string", "description": "Sinopse ou descrição" },
        "genre": { "type": "string", "description": "Categoria/Pasta" },
        "isRestricted": { "type": "boolean", "description": "Se requer senha parental" },
        "streamUrl": { "type": "string", "description": "Link da stream m3u8 ou youtube" }
      },
      "required": ["title", "type", "genre"]
    },
    "User": {
      "title": "Cliente",
      "description": "Perfil de acesso via PIN",
      "type": "object",
      "properties": {
        "pin": { "type": "string", "description": "Código de acesso único" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "Nível de acesso" },
        "subscriptionTier": { "type": "string", "enum": ["test", "monthly", "lifetime"], "description": "Tipo de plano" },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Data de expiração" },
        "resellerId": { "type": "string", "description": "ID do revendedor que gerou o PIN" },
        "activatedAt": { "type": "string", "format": "date-time", "description": "Data do primeiro login" }
      },
      "required": ["pin", "role"]
    },
    "Reseller": {
      "title": "Revendedor",
      "description": "Cadastro de parceiro de vendas",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "birthDate": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "credits": { "type": "number", "description": "Quantidade de PINs disponíveis para gerar" },
        "totalSold": { "type": "number", "description": "Total de PINs já vendidos" }
      },
      "required": ["name", "email", "cpf"]
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/content/{contentId}": {
      "schema": "ContentItem",
      "description": "Biblioteca de canais"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "PINs de clientes"
    },
    "/resellers/{resellerId}": {
      "schema": "Reseller",
      "description": "Cadastro de revendedores"
    }
  }
}
