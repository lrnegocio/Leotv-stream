
{
  "entities": {
    "ContentItem": {
      "title": "Item de Conteúdo",
      "description": "Filme, série ou canal de TV",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["movie", "series", "multi-season", "channel"] },
        "genre": { "type": "string" },
        "isRestricted": { "type": "boolean" },
        "streamUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "views": { "type": "number" }
      }
    },
    "User": {
      "title": "Cliente",
      "description": "Perfil de acesso via PIN",
      "type": "object",
      "properties": {
        "pin": { "type": "string" },
        "role": { "type": "string" },
        "gamePoints": { "type": "number" },
        "isSearchingMatch": { "type": "boolean" },
        "searchingMatchAt": { "type": "string", "format": "date-time" },
        "individualMessage": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/content/{contentId}": { "schema": "ContentItem", "description": "Biblioteca" },
    "/users/{userId}": { "schema": "User", "description": "PINs" }
  }
}
